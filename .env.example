# ─────────────────────────────────────────────────────────────────────────────
# IDA Environment Configuration
# Copy this file to .env and fill in every value.
#   cp .env.example .env
#
# .env is read by docker-compose for variable substitution only.
# It is NOT mounted inside any container. Keep it out of version control.
# ─────────────────────────────────────────────────────────────────────────────

# Generate with: openssl rand -hex 32
# Must be at least 32 characters. App refuses to start without this.
SECRET_KEY=REPLACE_WITH_OUTPUT_OF__openssl_rand_-hex_32

# The URL the browser uses to reach the backend.
# Local dev on one machine: http://localhost:8000
# Remote server:            https://api.your-domain.com
VITE_API_URL=http://localhost:8000
